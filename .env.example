# ============================================================
# LearnPath — Variables de entorno
# Copiar como .env y completar valores reales
# NUNCA commitear .env al repositorio
# ============================================================

# ----- Base de datos -----
POSTGRES_USER=learnpath
POSTGRES_PASSWORD=changeme_dev
POSTGRES_DB=learnpath_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://learnpath:changeme_dev@db:5432/learnpath_db

# ----- Redis -----
REDIS_URL=redis://redis:6379/0

# ----- Backend (FastAPI) -----
SECRET_KEY=super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://frontend:3000"]
ENVIRONMENT=development

# ----- Frontend (Next.js) -----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=LearnPath

# ----- Adminer (DB GUI) -----
ADMINER_DESIGN=pepa-linha

# ----- Producción (descomentar en prod) -----
# ENVIRONMENT=production
# SECRET_KEY=<generar con: openssl rand -hex 32>
# BACKEND_CORS_ORIGINS=["https://tudominio.com"]
# NEXT_PUBLIC_API_URL=https://api.tudominio.com
